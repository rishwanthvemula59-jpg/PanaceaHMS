# Port settings for the Express server
PORT=5000

# Supabase Credentials (from your Supabase Project Settings API page)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here (used for seeder bypass)

# JSON Web Token configurations
JWT_SECRET=your_jwt_secret_key_goes_here
JWT_EXPIRES_IN=24h

# Seeder Configurations
ADMIN_DEFAULT_EMAIL=admin@panaceameridian.com
ADMIN_DEFAULT_PASSWORD=admin123
